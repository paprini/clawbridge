{
  "name": "clawbridge",
  "version": "0.1.0",
  "description": "Bridge your OpenClaw agents across machines",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "setup": "node src/setup/cli.js",
    "setup:auto": "node src/setup/cli.js --non-interactive",
    "verify": "node src/verify.js",
    "status": "node src/cli.js status",
    "helper": "node src/cli.js helper",
    "peers": "node src/cli.js peers",
    "ping": "node src/cli.js ping",
    "call": "node src/cli.js call",
    "uninstall": "node scripts/uninstall.js"
  },
  "keywords": [
    "a2a",
    "agent-to-agent",
    "openclaw",
    "ai-agents",
    "interoperability",
    "clawbridge"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/paprini/clawbridge.git"
  },
  "author": "Guali Team",
  "license": "MIT",
  "dependencies": {
    "@a2a-js/sdk": "^0.3.10",
    "express": "^4.18.2",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "axios": "^1.6.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "eslint": "^8.55.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
